# Database
DB_URL=jdbc:mysql://localhost:3306/ptour_db?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=

# JWT  (generate a 256-bit base64 secret, e.g.: openssl rand -base64 32)
JWT_SECRET=change-me-in-production-at-least-32-chars-long
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URL (used for OAuth2 redirect)
FRONTEND_URL=http://localhost:3000

# OAuth2 - Google (create at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth2 - Facebook (create at https://developers.facebook.com)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Admin seeder (auto-created on first boot if not exists)
ADMIN_EMAIL=admin@ptittour.com
ADMIN_PASSWORD=Admin@123456

# Profile
SPRING_PROFILES_ACTIVE=dev
